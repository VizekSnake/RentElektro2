{
  "name": "frontend_rentelektro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint src --ext .js,.ts,.vue",
    "typecheck": "vue-tsc --noEmit",
    "generate:openapi": "../backend_rentelektro/.venv/bin/python ../backend_rentelektro/app/scripts/export_openapi.py --output ./openapi.json",
    "generate:api-types": "openapi-typescript ./openapi.json -o ./src/shared/api/generated/schema.ts",
    "sync:api-schema": "npm run generate:openapi && npm run generate:api-types"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "jwt-decode": "^4.0.0",
    "mitt": "^3.0.1",
    "openapi-fetch": "^0.17.0",
    "vue": "^3.5.31",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.4"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.12"
  },
  "overrides": {
    "lodash": "^4.18.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "parser": "vue-eslint-parser",
    "extends": [
      "plugin:vue/vue3-essential",
      "plugin:@typescript-eslint/recommended",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@typescript-eslint/parser",
      "ecmaVersion": "latest",
      "sourceType": "module",
      "extraFileExtensions": [
        ".vue"
      ]
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
